.claude/
.DS_Store

# Environment variables - never commit secrets
.env
.env.local
*.env

# Python build artifacts
__pycache__/
*.pyc

# Runtime usage logs (machine state, grow over time)
scripts/hubspot-usage.log
scripts/dall-e-usage.log
scripts/slack-usage.log

# Bundle outputs (too large for git; produced by weekly content engine)
aplus-content/

# State lock sidecars (transient — fcntl.flock anchors)
state/*.lock

# Embedding cache (rebuilt cheaply each CI run; would bloat repo)
state/blog-embeddings.json

# Case study Phase 1 — local-only files
scripts/*.bak
scripts/slack-case-study-usage.log
scripts/hubspot-usage.log
